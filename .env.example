# Supabase project URL (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase service role / secret key — server-only, bypasses Row Level Security.
# Never expose this to the client or commit it to git.
SUPABASE_SERVICE_ROLE_KEY=

# --- Afsoon Cleaning Team (/afsoon-cleaning) ---

# Twilio credentials used to text a new-quote-request alert. Server-only.
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Phone number that receives the SMS alert for each quote request (10-digit
# North American number, or E.164 like +16473001270).
SMS_NOTIFICATION_NUMBER=6473001270

# Resend API key used to send a backup email notification. Server-only.
# Get this from https://resend.com/api-keys
RESEND_API_KEY=

# Mailbox that receives the backup email notification for each quote request.
NOTIFICATION_EMAIL=info@winsalotcorp.com

# "From" address for the notification email. Must be on a domain you've
# verified in Resend (see https://resend.com/domains). Format:
# "Afsoon Cleaning Team <quotes@yourdomain.com>"
EMAIL_FROM=
