# Supabase project URL (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key (safe to expose to the browser — protected by Row
# Level Security). Used only to sign the admin dashboard in and out via
# Supabase Auth at /admin/login. Get this from Supabase → Project Settings →
# API → Project API keys → anon / public.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role / secret key — server-only, bypasses Row Level Security.
# Never expose this to the client or commit it to git.
SUPABASE_SERVICE_ROLE_KEY=

# --- Commercial cleaning quote page (/commercial-cleaning-quote) + admin dashboard ---

# Twilio credentials used to text a new-quote-request alert. Server-only.
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Phone number that receives the SMS alert for each quote request (10-digit
# North American number, or E.164 like +16473001270).
SMS_NOTIFICATION_NUMBER=6473001270

# Resend API key used to send a backup email notification. Server-only.
# Get this from https://resend.com/api-keys
RESEND_API_KEY=

# Mailbox that receives the backup email notification for each quote request.
NOTIFICATION_EMAIL=info@winsalotcorp.com

# "From" address for internal notification emails (new quote request,
# provider quote received, etc.) and, if unset, also the default for the
# customer-facing quote email below. Must be on a domain you've verified
# in Resend (see https://resend.com/domains). Format:
# "Quote Notifications <quotes@yourdomain.com>"
EMAIL_FROM=

# "From" address used specifically for the customer-facing quote email
# (sent only by the admin-only "Send Quote to Customer" button — never by
# agents). Falls back to EMAIL_FROM, then to
# "Winsalot Corp <info@winsalotcorp.com>", if unset. Do not point this at
# quotes@winsalotcorp.com or any other alias unless that address has been
# created and verified in Resend.
CUSTOMER_QUOTE_EMAIL_FROM=

# "Reply-To" address for the customer-facing quote email. Falls back to
# info@winsalotcorp.com if unset.
EMAIL_REPLY_TO=

# "From" address used specifically for the CRM's "Send Quote Request
# Email" button (/admin/crm/leads/[id] and /agent/leads/[id]). Falls back
# to EMAIL_FROM, then to "Winsalot Corp <info@winsalotcorp.com>", if
# unset. Same rationale as CUSTOMER_QUOTE_EMAIL_FROM above — this is a
# customer-facing email and should always read as Winsalot Corp's own
# address unless explicitly configured otherwise.
QUOTE_REQUEST_EMAIL_FROM=

# Absolute base URL of this site, used to build the "view in admin
# dashboard" link included in provider-quote notification emails/SMS, and
# the redirect link in agent invite/forgot-password emails. Set this to
# your production domain, e.g. https://cleaning.winsalotcorp.com.
#
# IMPORTANT: set this ONLY on the Production environment in Vercel
# (Project Settings -> Environment Variables -> scope to Production).
# Leave it unset on Preview - agent invite/reset links need to redirect
# back to the *same* preview deployment that sent them, not to
# production, and leaving this unset on Preview lets that fall back to
# the current deployment's own Vercel URL automatically. If unset
# everywhere, falls back to the Vercel deployment URL, then localhost.
NEXT_PUBLIC_SITE_URL=

# --- Active Cleaning Opportunities (/admin/opportunities) ---
# See docs/active-cleaning-opportunities.md for the full architecture,
# testing, and deployment guide.

# Shared secret the daily collection cron job must present as
# `Authorization: Bearer <value>`. Set this as a Vercel project env var and
# Vercel automatically sends it on every Cron Job invocation once a
# `crons` entry exists in vercel.json (not added yet - see the docs above).
# Without it, GET /api/cron/cleaning-opportunities always returns 401.
CRON_SECRET=

# Mailbox that receives the "new Hot opportunity discovered" alert email.
# Falls back to info@winsalotcorp.com if unset.
OPPORTUNITY_ALERT_EMAIL=info@winsalotcorp.com

# --- CRM email delivery tracking (Resend webhooks) ---
# See docs/crm.md#email-delivery-tracking for the full setup guide.

# Signing secret for the Resend webhook endpoint (POST /api/webhooks/resend).
# Get this from Resend -> Webhooks -> (your endpoint) -> Signing Secret
# after creating the endpoint. Required for the webhook to work at all -
# without it, every request to /api/webhooks/resend is rejected with 500.
RESEND_WEBHOOK_SECRET=
